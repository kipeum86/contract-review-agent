/contract-review/library/inbox/raw/*
!/contract-review/library/inbox/raw/.gitkeep
/contract-review/library/inbox/sidecars/*
!/contract-review/library/inbox/sidecars/.gitkeep
/contract-review/library/staging/*
!/contract-review/library/staging/.gitkeep
/contract-review/library/approved/*
!/contract-review/library/approved/.gitkeep
/contract-review/library/quarantine/*
!/contract-review/library/quarantine/.gitkeep
